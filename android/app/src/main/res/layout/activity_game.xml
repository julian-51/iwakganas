<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <!-- Game Surface -->
    <com.julian.iwakganas.view.GameSurfaceView
        android:id="@+id/game_surface_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Pause Button (top-right corner) -->
    <Button
        android:id="@+id/btn_pause"
        android:layout_width="60dp"
        android:layout_height="40dp"
        android:layout_gravity="top|end"
        android:layout_margin="8dp"
        android:text="II"
        android:textSize="14sp"
        android:textStyle="bold"
        android:backgroundTint="#AA000000"
        android:textColor="@android:color/white"
        android:alpha="0.8" />

    <!-- Pause Overlay -->
    <LinearLayout
        android:id="@+id/pause_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#CC000000"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PAUSED"
            android:textColor="@android:color/white"
            android:textSize="36sp"
            android:textStyle="bold"
            android:layout_marginBottom="32dp" />

        <Button
            android:id="@+id/btn_resume"
            android:layout_width="200dp"
            android:layout_height="55dp"
            android:layout_marginBottom="16dp"
            android:text="Resume"
            android:textSize="16sp"
            android:backgroundTint="@color/button_color" />

        <Button
            android:id="@+id/btn_restart"
            android:layout_width="200dp"
            android:layout_height="55dp"
            android:layout_marginBottom="16dp"
            android:text="Restart"
            android:textSize="16sp"
            android:backgroundTint="@color/button_color" />

        <Button
            android:id="@+id/btn_quit_to_menu"
            android:layout_width="200dp"
            android:layout_height="55dp"
            android:text="Quit to Menu"
            android:textSize="16sp"
            android:backgroundTint="@color/button_exit_color" />

    </LinearLayout>

</FrameLayout>
